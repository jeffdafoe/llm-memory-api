[Unit]
Description=Memory API
After=network.target postgresql.service

[Service]
Type=simple
User={{ app_user }}
{% if repo_root == project_root %}
WorkingDirectory={{ project_root }}/node/api
{% else %}
WorkingDirectory={{ project_root }}
{% endif %}
EnvironmentFile=/etc/memory-api/env
ExecStart=/usr/bin/node src/server.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
