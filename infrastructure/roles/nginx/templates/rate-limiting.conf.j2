# Rate limiting zones — managed by Ansible
# Included in the http {} block via conf.d

# Conditional zone key: empty string for loopback so server-local callers
# (e.g. processes on the VPS hitting the API via nginx) are not rate-limited.
# nginx skips limit_req entirely when the key is empty.
geo $limit_key {
    default     $binary_remote_addr;
    127.0.0.1   "";
    ::1         "";
}

limit_req_zone $limit_key zone=auth_limit:10m rate=5r/s;
limit_req_zone $limit_key zone=api_limit:10m rate=30r/s;
