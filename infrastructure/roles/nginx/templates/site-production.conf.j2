# {{ project_name }} — managed by Ansible
# Multi-domain reverse proxy for the memory API

# Default catch-all — drop unmatched requests
# Prevents fallback to other server blocks (e.g., downtowndevelopmentplan.com)
server {
    listen 80 default_server;
    server_name _;
    return 444;
}

server {
    listen 443 ssl default_server;
    server_name _;

    ssl_certificate /etc/letsencrypt/live/{{ server_name_list[0] }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_name_list[0] }}/privkey.pem;

    return 444;
}

{% for domain in server_name_list %}
# HTTP → HTTPS redirect for {{ domain }}
server {
    listen 80;
    server_name {{ domain }} www.{{ domain }};
    return 301 https://{{ domain }}$request_uri;
}

# HTTPS www → non-www redirect for {{ domain }}
server {
    listen 443 ssl;
    server_name www.{{ domain }};

    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://{{ domain }}$request_uri;
}

# HTTPS server for {{ domain }}
server {
    listen 443 ssl;
    server_name {{ domain }};

    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Allow large request bodies (conversation log uploads can be several MB)
    client_max_body_size 10m;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=86400; includeSubDomains" always;

    # Block WordPress/CMS scanning bots — return 444 (drop connection, no response body)
    # Logged so fail2ban can detect repeat offenders and ban their IP
    location ~* ^/(wp-admin|wp-login|wp-content|wp-includes|wordpress|xmlrpc\.php|wp-cron\.php) {
        return 444;
    }

    # Rate-limited auth endpoints — 5 req/s per IP, burst of 10 with delay
    location /v1/agent/login {
        limit_req zone=auth_limit burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /v1/admin/login {
        limit_req zone=auth_limit burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # OAuth endpoints — rate-limited (mounted at root, not under /v1/)
    location = /oauth/token {
        limit_req zone=auth_limit burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /authorize {
        limit_req zone=auth_limit burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Rate-limited public endpoints (registration, access requests)
    location /api/ {
        limit_req zone=auth_limit burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket upgrade for admin real-time events
    location /admin/ws {
        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400s;
    }

    # Static assets served directly by nginx (logos, images)
    location /static/ {
        alias {{ project_root }}/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Downloadable tools (Go binaries etc.)
    location /tools/ {
        alias /var/www/tools/;
        expires 1h;
        add_header Cache-Control "public";
    }

{% if domain not in public_domains %}
    # Root URL → admin dashboard (internal domain only)
    location = / {
        return 302 /admin/;
    }
{% endif %}

    # Custom error page for upstream failures (e.g. during deploys)
    # Prevents browsers from caching stale pages when the app is briefly unavailable
    error_page 502 503 /maintenance.html;
    location = /maintenance.html {
        root /var/www/{{ project_name }};
        internal;
        add_header Cache-Control "no-store" always;
    }

    # All other requests — rate limited to prevent DB exhaustion via auth checks
    location / {
        limit_req zone=api_limit burst=60 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:{{ memory_api_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE/streaming support for MCP
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
        proxy_http_version 1.1;
        proxy_set_header Connection "";

        proxy_intercept_errors on;
    }

    access_log /var/log/nginx/{{ project_name }}_{{ domain }}_access.log;
    error_log /var/log/nginx/{{ project_name }}_{{ domain }}_error.log;
}

{% endfor %}
